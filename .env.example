# =================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# =================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!
# =================================================================

# =================================================================
# GOOGLE CLOUD / BIGQUERY CONFIGURATION
# =================================================================
# Your GCP Project ID
GCP_PROJECT_ID=your-project-id-here

# BigQuery dataset and table
GCP_DATASET=your-dataset
GCP_TABLE=your-table-name

# Path to service account JSON key file
# Download from GCP Console: IAM & Admin > Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# =================================================================
# EMAIL NOTIFICATION CONFIGURATION
# =================================================================
# Enable/disable email notifications
EMAIL_ENABLED=true

# SMTP server configuration
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Email credentials
EMAIL_USERNAME=your-email@example.com
EMAIL_PASSWORD=your-app-password

# Sender and recipient addresses
EMAIL_FROM=data-quality-alerts@example.com
EMAIL_TO=team@example.com,manager@example.com

# =================================================================
# APPLICATION CONFIGURATION
# =================================================================
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Query timeout in seconds
BIGQUERY_TIMEOUT=300

# Maximum query cost in bytes (prevents expensive queries)
# Default: 1GB = 1073741824 bytes
MAX_QUERY_BYTES=1073741824

# =================================================================
# OPTIONAL: ADVANCED CONFIGURATION
# =================================================================
# Number of weeks to look back for seasonality analysis
LOOKBACK_WEEKS=8

# Timezone for reporting (default: UTC)
TIMEZONE=UTC

